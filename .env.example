# IrishTaxHub MCP configuration
IRISHTAXHUB_BASE_URL=http://localhost:5000
IRISHTAXHUB_TIMEOUT=30
# Optional OpenAPI source (file path or URL). If omitted, server will try
# /apispec_1.json, /openapi.json, or /apidocs/spec.json on the base URL.
IRISHTAXHUB_OPENAPI=http://localhost:5000/openapi.json
# Controls Jinja rendering when loading a templated YAML spec from file
IRISHTAXHUB_DEVELOPMENT_MODE=true
